{
  "name": "mukti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mukti conversion engine — Bijoy/SutonnyMJ Bangla to Unicode (pure TypeScript core).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:engine": "tsc -p tsconfig.json",
    "lint": "eslint . && tsc -p tsconfig.json --noEmit",
    "test": "npm run build:engine && node tools/validate-data.mjs && node --test \"test/**/*.test.mjs\"",
    "validate:data": "node tools/validate-data.mjs",
    "corpus:visible": "node tools/corpus/harness.mjs --dir corpus/visible --converter dist/engine/index.js --threshold 0.99",
    "corpus:heldout": "node tools/corpus/harness.mjs --dir corpus/heldout --converter dist/engine/index.js --threshold 0.99",
    "freeze:check": "node tools/corpus/freeze.mjs --check",
    "corpus:gate": "npm run build:engine && npm run corpus:visible && npm run corpus:heldout && npm run freeze:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ajv": "^8.17.1",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "typescript": "^5.7.2"
  }
}
