{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/gru-953/mukti/data/schema/mapping-table.schema.json",
  "title": "Mukti mapping profile",
  "description": "A static, maintainer-edited Bijoy->Unicode mapping profile. Data only: code-point arrays and literal replacement strings. There are NO user/profile-supplied regular expressions, so the format is regex-DoS-safe by construction (the engine compiles entries into a single longest-match alternation it controls).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "map", "reorder"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "license": { "type": "string", "description": "Provenance/licence of this independently-authored table." },
    "preMap": { "$ref": "#/$defs/entryList" },
    "map": { "$ref": "#/$defs/entryList" },
    "postMap": { "$ref": "#/$defs/entryList" },
    "reorder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preBaseVowels", "reph"],
      "properties": {
        "preBaseVowels": { "type": "boolean" },
        "reph": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "entryList": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target"],
      "properties": {
        "source": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0, "maximum": 1114111 },
          "description": "Bijoy source glyph(s) as Unicode code points (the values the engine receives)."
        },
        "target": {
          "type": "string",
          "description": "Unicode replacement (authoring form; engine emits NFC)."
        },
        "note": { "type": "string" }
      }
    }
  }
}
