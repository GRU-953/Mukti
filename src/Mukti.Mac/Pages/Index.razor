@page "/"
@using Mukti.Engine
@inject IJSRuntime JS
@inject HttpClient Http

<div class="mukti-panel">
    <div class="mukti-header">
        <img src="mukti-icon.svg" class="mukti-logo" alt="Mukti" />
        <span class="mukti-title">@(_isEnglish ? "Mukti" : "à¦®à§à¦•à§à¦¤à¦¿")</span>
        <button class="btn-lang" @onclick="ToggleLanguage">@(_isEnglish ? "à¦¬à¦¾à¦‚à¦²à¦¾" : "EN")</button>
    </div>
    <div class="mukti-subtitle">@(_isEnglish ? "Bijoy / SutonnyMJ â†’ Unicode Bengali" : "à¦¬à¦¿à¦œà¦¯à¦¼ à¦¥à§‡à¦•à§‡ à¦‡à¦‰à¦¨à¦¿à¦•à§‹à¦¡ à¦°à§‚à¦ªà¦¾à¦¨à§à¦¤à¦°")</div>

    @if (!string.IsNullOrEmpty(_updateBannerText))
    {
        <div class="update-banner" @onclick="OpenReleasePage">
            @_updateBannerText
        </div>
    }

    <button class="btn-primary" @onclick="ScanDocument" disabled="@(_scanning || _converter == null)">
        @if (_scanning) { <span class="mukti-spinner" aria-hidden="true"></span> }
        @(_scanning ? (_isEnglish ? "Scanning..." : "à¦¸à§à¦•à§à¦¯à¦¾à¦¨ à¦¹à¦šà§à¦›à§‡...") : (_isEnglish ? "Scan Document" : "à¦¸à§à¦•à§à¦¯à¦¾à¦¨ à¦•à¦°à§à¦¨"))
    </button>

    @* U-011: Scan Selection *@
    <button class="btn-secondary" @onclick="ScanSelection" disabled="@(_scanning || _converter == null)">
        @(_isEnglish ? "Scan Selection" : "à¦¨à¦¿à¦°à§à¦¬à¦¾à¦šà¦¿à¦¤ à¦¸à§à¦•à§à¦¯à¦¾à¦¨ à¦•à¦°à§à¦¨")
    </button>

    @if (_noDocOpen)
    {
        <div class="no-doc-box">
            <span class="no-doc-icon" aria-hidden="true">&#x2299;</span>
            <span>@(_isEnglish ? "No document open. Open a Word, Excel, or PowerPoint file first." : "à¦•à§‹à¦¨à§‹ à¦¨à¦¥à¦¿ à¦–à§‹à¦²à¦¾ à¦¨à§‡à¦‡à¥¤ à¦ªà§à¦°à¦¥à¦®à§‡ Word, Excel à¦¬à¦¾ PowerPoint à¦«à¦¾à¦‡à¦² à¦–à§à¦²à§à¦¨à¥¤")</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(_status))
    {
        <div class="status-box">@_status</div>
    }

    @if (!string.IsNullOrEmpty(_warning))
    {
        <div class="warning-box">@_warning</div>
    }

    @if (_previewItems.Count > 0)
    {
        <div class="preview-header">@(_isEnglish ? "Changes to apply:" : "à¦ªà¦°à¦¿à¦¬à¦°à§à¦¤à¦¨à§‡à¦° à¦¤à¦¾à¦²à¦¿à¦•à¦¾:")</div>
        <div class="preview-scroll">
            <table class="preview-table">
                <thead><tr><th>@(_isEnglish ? "Before" : "à¦†à¦—à§‡")</th><th>@(_isEnglish ? "After" : "à¦ªà¦°à§‡")</th></tr></thead>
                <tbody>
                    @foreach (var item in _previewItems)
                    {
                        <tr><td class="before-col">@item.Before</td><td class="after-col">@item.After</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <button class="btn-primary" @onclick="ApplyConversion" disabled="@_applying">
            @(_applying ? (_isEnglish ? "Applying..." : "à¦ªà§à¦°à¦¯à¦¼à§‹à¦— à¦¹à¦šà§à¦›à§‡...") : (_isEnglish ? "Apply Conversion" : "à¦°à§‚à¦ªà¦¾à¦¨à§à¦¤à¦° à¦•à¦°à§à¦¨"))
        </button>
    }

    @if (_canUndo)
    {
        <button class="btn-secondary" @onclick="UndoConversion">@(_isEnglish ? "Undo Conversion" : "à¦ªà§‚à¦°à§à¦¬à¦¾à¦¬à¦¸à§à¦¥à¦¾à¦¯à¦¼ à¦«à§‡à¦°à¦¾à¦¨")</button>
    }

    <div class="footer-note">@(_isEnglish ? "Your document content never leaves your device." : "à¦†à¦ªà¦¨à¦¾à¦° à¦¨à¦¥à¦¿à¦° à¦¬à¦¿à¦·à¦¯à¦¼à¦¬à¦¸à§à¦¤à§ à¦•à¦–à¦¨à¦“ à¦¡à¦¿à¦­à¦¾à¦‡à¦¸à§‡à¦° à¦¬à¦¾à¦‡à¦°à§‡ à¦¯à¦¾à¦¯à¦¼ à¦¨à¦¾à¥¤")</div>
</div>

@code {
    bool _isEnglish = false, _scanning = false, _applying = false, _canUndo = false, _noDocOpen = false, _lowMemory = false;
    int _hardwareCores = 1;
    string _status = "", _warning = "", _currentHost = "", _updateBannerText = "";
    List<PreviewRow> _previewItems = new();
    List<ScanRun> _snapshot = new();
    Converter? _converter;
    FontRegistry? _fontRegistry;

    protected override async Task OnInitializedAsync()
    {
        try {
            var lang = await JS.InvokeAsync<string>("muktiOffice.getDisplayLanguage");
            _isEnglish = !lang.StartsWith("bn", StringComparison.OrdinalIgnoreCase);
        } catch { _isEnglish = false; }

        try {
            var hw = await JS.InvokeAsync<HardwareHint>("muktiOffice.getHardwareHint");
            _hardwareCores = hw.Cores;
            _lowMemory = hw.LowMem;
        } catch { }

        try {
            var json = await Http.GetStringAsync("data/bijoy-sutonnymj.json");
            var glyphMap = new GlyphMap(json, isContent: true);
            _converter = new Converter(glyphMap);
            _fontRegistry = new FontRegistry();
        } catch (Exception ex) {
            _status = "Engine load error: " + ex.Message;
        }
        _ = CheckForUpdateAsync();
    }

    void ToggleLanguage() => _isEnglish = !_isEnglish;

    async Task ScanDocument() => await PerformScan(selectionOnly: false);

    // U-011: scan selected text only
    async Task ScanSelection() => await PerformScan(selectionOnly: true);

    async Task PerformScan(bool selectionOnly)
    {
        _scanning = true; _status = ""; _warning = ""; _currentHost = ""; _noDocOpen = false;
        _previewItems.Clear(); _snapshot.Clear(); _canUndo = false;
        StateHasChanged();
        try {
            if (_converter == null || _fontRegistry == null) { _status = _isEnglish ? "Engine not ready." : "à¦‡à¦žà§à¦œà¦¿à¦¨ à¦ªà§à¦°à¦¸à§à¦¤à§à¦¤ à¦¨à§‡à¦‡à¥¤"; return; }
            var bijoyFonts = _fontRegistry.KnownBijoyFonts.Select(f => f.ToLowerInvariant()).ToArray();
            var markers = _fontRegistry.BengaliMarkers.ToArray();
            var host = await JS.InvokeAsync<string>("muktiOffice.getHostName");
            _currentHost = host;

            ScanResult? scanResult = null;
            if (host == "Word")
            {
                var fn = selectionOnly ? "muktiOffice.scanWordSelection" : "muktiOffice.scanWordDocument";
                scanResult = await JS.InvokeAsync<ScanResult>(fn, new object[] { bijoyFonts, markers });
            }
            else if (host == "Excel")
            {
                var fn = selectionOnly ? "muktiOffice.scanExcelSelection" : "muktiOffice.scanExcelDocument";
                scanResult = await JS.InvokeAsync<ScanResult>(fn, new object[] { bijoyFonts, markers });
            }
            else if (host == "PowerPoint")
                scanResult = await JS.InvokeAsync<ScanResult>("muktiOffice.scanPowerPointDocument", new object[] { bijoyFonts, markers });
            else if (host == "None") {
                _noDocOpen = true;
                return;
            }
            else {
                _status = _isEnglish ? $"{host}: scanning not supported." : $"{host}: à¦¸à§à¦•à§à¦¯à¦¾à¦¨ à¦¸à¦®à¦°à§à¦¥à¦¿à¦¤ à¦¨à¦¯à¦¼à¥¤";
                return;
            }

            int alreadyUnicodeCount = 0;
            if (scanResult?.Runs == null || scanResult.Runs.Count == 0)
            {
                _status = _isEnglish ? "No Bijoy text found." : "à¦•à§‹à¦¨à§‹ à¦¬à¦¿à¦œà¦¯à¦¼ à¦²à§‡à¦–à¦¾ à¦ªà¦¾à¦“à¦¯à¦¼à¦¾ à¦¯à¦¾à¦¯à¦¼à¦¨à¦¿à¥¤";
            }
            else
            {
                // On low-memory or single-core machines, rendering tens of thousands of preview
                // rows in WASM can freeze the browser. Cap the visible preview but keep the full
                // snapshot, so Apply still converts every run.
                int previewCap = (_lowMemory || _hardwareCores <= 1) ? 200 : int.MaxValue;
                foreach (var run in scanResult.Runs) {
                    if (Converter.DetectScript(run.Text) == ScriptType.UnicodeBn)
                        alreadyUnicodeCount++;
                    var converted = _converter.Convert(run.Text);
                    if (converted != run.Text) {
                        _snapshot.Add(new ScanRun { Original = run.Text, Converted = converted, FontName = run.FontName, ParaIndex = run.ParaIndex, RunIndex = run.RunIndex, SheetIndex = run.SheetIndex });
                        if (_previewItems.Count < previewCap)
                            _previewItems.Add(new PreviewRow { Before = run.Text.Trim(), After = converted.Trim() });
                    }
                }
                int total = _snapshot.Count;
                if (total == 0)
                    _status = _isEnglish ? "Nothing to convert." : "à¦°à§‚à¦ªà¦¾à¦¨à§à¦¤à¦°à§‡à¦° à¦•à¦¿à¦›à§ à¦¨à§‡à¦‡à¥¤";
                else if (_previewItems.Count < total)
                    _status = _isEnglish
                        ? $"Found {total} run(s) â€” showing first {_previewItems.Count} (low-resource mode)."
                        : $"{total}à¦Ÿà¦¿ à¦°à¦¾à¦¨ à¦ªà¦¾à¦“à¦¯à¦¼à¦¾ à¦—à§‡à¦›à§‡ â€” à¦ªà§à¦°à¦¥à¦® {_previewItems.Count}à¦Ÿà¦¿ à¦¦à§‡à¦–à¦¾à¦¨à§‹ à¦¹à¦šà§à¦›à§‡ (à¦•à¦®-à¦°à¦¿à¦¸à§‹à¦°à§à¦¸ à¦®à§‹à¦¡)à¥¤";
                else
                    _status = _isEnglish ? $"Found {total} run(s)." : $"{total}à¦Ÿà¦¿ à¦°à¦¾à¦¨ à¦ªà¦¾à¦“à¦¯à¦¼à¦¾ à¦—à§‡à¦›à§‡à¥¤";
            }

            var warningParts = new List<string>();
            if (scanResult?.FormulaSkippedCount > 0)
                warningParts.Add(_isEnglish
                    ? $"{scanResult.FormulaSkippedCount} formula cell(s) skipped"
                    : $"{scanResult.FormulaSkippedCount}à¦Ÿà¦¿ à¦¸à§‚à¦¤à§à¦° à¦¸à§‡à¦² à¦¬à¦¾à¦¦ à¦¦à§‡à¦“à¦¯à¦¼à¦¾ à¦¹à¦¯à¦¼à§‡à¦›à§‡");
            if (scanResult?.Warnings != null && scanResult.Warnings.Count > 0)
                warningParts.Add((_isEnglish ? "Unknown fonts: " : "à¦…à¦œà¦¾à¦¨à¦¾ à¦«à¦¨à§à¦Ÿ: ") + string.Join(", ", scanResult.Warnings));
            if (alreadyUnicodeCount > 0)
                warningParts.Add(_isEnglish
                    ? $"{alreadyUnicodeCount} run{(alreadyUnicodeCount == 1 ? "" : "s")} already in Unicode Bengali — skipped."
                    : $"{alreadyUnicodeCount}টি রান ইতিমধ্যে ইউনিকোড বাংলায় রয়েছে — এড়িয়ে যাওয়া হয়েছে।");
            if (warningParts.Count > 0)
                _warning = string.Join(" | ", warningParts);

        } catch (Exception ex) { _status = (_isEnglish ? "Error: " : "à¦¤à§à¦°à§à¦Ÿà¦¿: ") + ex.Message; }
        finally { _scanning = false; StateHasChanged(); }
    }

    async Task ApplyConversion()
    {
        if (_snapshot.Count == 0) return;
        _applying = true; StateHasChanged();
        try {
            var payload = _snapshot.Select(s => new { original = s.Original, converted = s.Converted, paraIndex = s.ParaIndex, runIndex = s.RunIndex, sheetIndex = s.SheetIndex }).ToArray();
            var jsFn = _currentHost == "Excel" ? "muktiOffice.applyExcelConversion"
                     : _currentHost == "PowerPoint" ? "muktiOffice.applyPowerPointConversion"
                     : "muktiOffice.applyWordConversion";
            await JS.InvokeAsync<bool>(jsFn, payload, "Noto Sans Bengali");
            _status = _isEnglish ? $"Done â€” {_snapshot.Count} run(s) converted." : $"à¦¸à¦®à§à¦ªà¦¨à§à¦¨ â€” {_snapshot.Count}à¦Ÿà¦¿ à¦°à¦¾à¦¨ à¦°à§‚à¦ªà¦¾à¦¨à§à¦¤à¦°à¦¿à¦¤à¥¤";
            _previewItems.Clear(); _canUndo = true;
        } catch (Exception ex) { _status = (_isEnglish ? "Error: " : "à¦¤à§à¦°à§à¦Ÿà¦¿: ") + ex.Message; }
        finally { _applying = false; StateHasChanged(); }
    }

    async Task UndoConversion()
    {
        if (_snapshot.Count == 0) return;
        try {
            var payload = _snapshot.Select(s => new { original = s.Original, converted = s.Converted, fontName = s.FontName, paraIndex = s.ParaIndex, runIndex = s.RunIndex, sheetIndex = s.SheetIndex }).ToArray();
            var jsFn = _currentHost == "Excel" ? "muktiOffice.revertExcelConversion"
                     : _currentHost == "PowerPoint" ? "muktiOffice.revertPowerPointConversion"
                     : "muktiOffice.revertWordConversion";
            await JS.InvokeAsync<bool>(jsFn, payload);
            _status = _isEnglish ? "Reverted successfully." : "à¦ªà§‚à¦°à§à¦¬à¦¾à¦¬à¦¸à§à¦¥à¦¾à¦¯à¦¼ à¦«à§‡à¦°à¦¾à¦¨à§‹ à¦¹à¦¯à¦¼à§‡à¦›à§‡à¥¤";
            _canUndo = false; _previewItems.Clear(); _snapshot.Clear();
        } catch (Exception ex) { _status = (_isEnglish ? "Revert error: " : "à¦«à§‡à¦°à¦¾à¦¨à§‹à¦¯à¦¼ à¦¤à§à¦°à§à¦Ÿà¦¿: ") + ex.Message; }
        StateHasChanged();
    }

    async Task CheckForUpdateAsync()
    {
        const string current = "2.0.17";
        try
        {
            Http.DefaultRequestHeaders.TryAddWithoutValidation("User-Agent", "Mukti-Mac");
            var json = await Http.GetStringAsync("https://api.github.com/repos/GRU-953/Mukti/releases/latest");
            var m = System.Text.RegularExpressions.Regex.Match(json, @"""tag_name""\s*:\s*""v?([\d.]+)""");
            if (!m.Success) return;
            var latest = m.Groups[1].Value;
            if (new Version(latest) > new Version(current))
            {
                _updateBannerText = _isEnglish
                    ? $"New version {latest} available â€” click to download"
                    : $"à¦¨à¦¤à§à¦¨ à¦¸à¦‚à¦¸à§à¦•à¦°à¦£ {latest} à¦ªà¦¾à¦“à¦¯à¦¼à¦¾ à¦—à§‡à¦›à§‡ â€” à¦¡à¦¾à¦‰à¦¨à¦²à§‹à¦¡ à¦•à¦°à¦¤à§‡ à¦•à§à¦²à¦¿à¦• à¦•à¦°à§à¦¨";
                StateHasChanged();
            }
        }
        catch { }
    }

    void OpenReleasePage()
    {
        try { _ = JS.InvokeAsync<object>("window.open", "https://github.com/GRU-953/Mukti/releases/latest", "_blank"); }
        catch { }
    }

    class PreviewRow { public string Before { get; set; } = ""; public string After { get; set; } = ""; }
    class ScanRun { public string Original { get; set; } = ""; public string Converted { get; set; } = ""; public string FontName { get; set; } = ""; public int ParaIndex { get; set; } public int RunIndex { get; set; } public int SheetIndex { get; set; } }
    class ScanResult { public List<RunEntry> Runs { get; set; } = new(); public List<string> Warnings { get; set; } = new(); public int FormulaSkippedCount { get; set; } }
    class RunEntry { public string Text { get; set; } = ""; public string FontName { get; set; } = ""; public int ParaIndex { get; set; } public int RunIndex { get; set; } public int SheetIndex { get; set; } }
    record HardwareHint([property: System.Text.Json.Serialization.JsonPropertyName("cores")] int Cores,
                        [property: System.Text.Json.Serialization.JsonPropertyName("lowMem")] bool LowMem);
}
