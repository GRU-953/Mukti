<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Mukti.WindowsAddin.MuktiPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFFFFF" FontFamily="DM Sans, Segoe UI, Tahoma" FontSize="13">
  <UserControl.Resources>
    <!-- Primary button — GRU953 Teal 700 -->
    <Style x:Key="MuktiButton" TargetType="Button">
      <Setter Property="Background" Value="#0A6E5C"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="Margin" Value="0,4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#0D8C73"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#E2EAE7"/>
                <Setter Property="Foreground" Value="#8FA8A2"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- Secondary button — GRU953 Indigo 700 -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource MuktiButton}">
      <Setter Property="Background" Value="#26336E"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2E3D85"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#E2EAE7"/>
                <Setter Property="Foreground" Value="#8FA8A2"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="12,12,12,12">

      <!-- Update banner (U-002, hidden by default) -->
      <Border x:Name="panelUpdateBanner" Background="#E8F4F1" BorderBrush="#0A6E5C" BorderThickness="1"
              CornerRadius="6" Padding="8,6" Margin="0,0,0,8" Visibility="Collapsed">
          <TextBlock x:Name="txtUpdateBanner" TextWrapping="Wrap" FontSize="12"
                     Foreground="#0A6E5C" Cursor="Hand" MouseLeftButtonUp="BtnUpdate_Click"/>
      </Border>

      <!-- Header: logo + title + lang toggle -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
        <!-- Brand icon (28×28 rounded) -->
        <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,8,0">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#3A4A9E" Offset="0"/>
              <GradientStop Color="#0A6E5C" Offset="0.6"/>
              <GradientStop Color="#14A88A" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
          <TextBlock Text="ম" FontSize="16" FontWeight="Bold" Foreground="#F4B53C"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontFamily="Noto Sans Bengali, Vrinda, Tahoma"/>
        </Border>
        <TextBlock x:Name="txtTitle" Text="মুক্তি" FontSize="20" FontWeight="Bold"
                   Foreground="#26336E" VerticalAlignment="Center"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
        <Button x:Name="btnLang" Content="EN" Width="38" Height="26" Margin="8,0,0,0"
                FontSize="11" FontWeight="SemiBold"
                Cursor="Hand" Click="BtnLang_Click">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="#E8F4F1" CornerRadius="5"
                      BorderBrush="#14A88A" BorderThickness="1"
                      Padding="4,2">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#E2EAE7"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
          <Button.Foreground><SolidColorBrush Color="#0A6E5C"/></Button.Foreground>
        </Button>
      </StackPanel>

      <!-- Subtitle -->
      <TextBlock x:Name="txtSubtitle" Text="বিজয় থেকে ইউনিকোড রূপান্তর"
                 FontSize="11" Foreground="#4A6360" Margin="0,0,0,12" TextWrapping="Wrap"
                 FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>

      <!-- Scan Document -->
      <Button x:Name="btnScan" Style="{StaticResource MuktiButton}"
              Click="BtnScan_Click">
        <TextBlock x:Name="txtScanBtn" Text="স্ক্যান করুন" FontSize="14" FontWeight="SemiBold"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
      </Button>

      <!-- U-011: Scan Selection -->
      <Button x:Name="btnScanSelection" Style="{StaticResource SecondaryButton}"
              Click="BtnScanSelection_Click">
        <TextBlock x:Name="txtScanSelectionBtn" Text="নির্বাচিত স্ক্যান করুন" FontSize="13" FontWeight="SemiBold"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
      </Button>

      <!-- Status panel -->
      <Border x:Name="panelStatus" Background="#E8F4F1" CornerRadius="8"
              Padding="10,8" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="txtStatus" TextWrapping="Wrap" FontSize="12"
                   Foreground="#0F2420"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
      </Border>
      <ProgressBar x:Name="progressScan" IsIndeterminate="True" Height="4"
                   Margin="0,4,0,0" Visibility="Collapsed"
                   Foreground="#0A6E5C" Background="#E2EAE7"/>

      <!-- Warning panel -->
      <Border x:Name="panelWarning" Background="#FEF9EC" CornerRadius="8"
              BorderBrush="#E0990F" BorderThickness="1"
              Padding="10,8" Margin="0,6,0,0" Visibility="Collapsed">
        <TextBlock x:Name="txtWarning" TextWrapping="Wrap" FontSize="11"
                   Foreground="#5A3D00"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
      </Border>

      <!-- Preview list header -->
      <TextBlock x:Name="txtPreviewHeader" Text="পরিবর্তনের তালিকা" FontSize="12"
                 FontWeight="SemiBold" Foreground="#26336E" Margin="0,12,0,4"
                 Visibility="Collapsed"
                 FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>

      <!-- Preview list -->
      <ListView x:Name="lstPreview" MaxHeight="300" Margin="0,0,0,8"
                Visibility="Collapsed" BorderBrush="#E2EAE7" BorderThickness="1"
                Background="#FAFCFB">
        <ListView.View>
          <GridView>
            <GridViewColumn x:Name="colBefore" Header="আগে" Width="130"
              DisplayMemberBinding="{Binding Before}"/>
            <GridViewColumn x:Name="colAfter" Header="পরে" Width="130"
              DisplayMemberBinding="{Binding After}"/>
          </GridView>
        </ListView.View>
      </ListView>

      <!-- Apply conversion -->
      <Button x:Name="btnApply" Style="{StaticResource MuktiButton}"
              IsEnabled="False" Click="BtnApply_Click">
        <TextBlock x:Name="txtApplyBtn" Text="রূপান্তর করুন"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
      </Button>

      <!-- Undo -->
      <Button x:Name="btnUndo" Style="{StaticResource SecondaryButton}"
              IsEnabled="False" Visibility="Visible" Click="BtnUndo_Click">
        <TextBlock x:Name="txtUndoBtn" Text="পূর্বাবস্থায় ফেরান"
                   FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
      </Button>

      <!-- Footer -->
      <TextBlock x:Name="txtFooter" Margin="0,16,0,0" FontSize="10"
                 Foreground="#8FA8A2" TextWrapping="Wrap"
                 Text="আপনার নথির বিষয়বস্তু কখনও ডিভাইসের বাইরে যায় না।"
                 FontFamily="Noto Sans Bengali, DM Sans, Segoe UI"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
