<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="tabMukti" label="Mukti" insertAfterMso="TabHome">
        <group id="grpBengali" label="Bengali" getLabel="GetGroupLabel">
          <toggleButton id="btnMukti"
            size="large"
            label="Mukti"
            screentip="Mukti — Bengali Converter"
            supertip="Convert Bijoy/SutonnyMJ encoded text to Unicode Bengali. Click to show or hide the Mukti panel."
            getPressed="GetTaskPaneVisible"
            onAction="ToggleTaskPane"
            tag="showTaskPane"
            getImage="GetRibbonImage" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
